    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const patientData = $node[\"Code in JavaScript\"].json;\nconst fecha = patientData.fecha_cita.replace(/-/g, '');\nconst horaStart = patientData.hora_cita.replace(/:/g, '') + '00';\nconst [h, m] = patientData.hora_cita.split(':').map(Number);\nconst endM = (m + 30) % 60;\nconst endH = h + Math.floor((m + 30) / 60);\nconst endHStr = String(endH).padStart(2, '0');\nconst endMStr = String(endM).padStart(2, '0');\nconst horaEnd = endHStr + endMStr + '00';\nconst dtstart = fecha + 'T' + horaStart;\nconst dtend = fecha + 'T' + horaEnd;\nconst dtstamp = new Date().toISOString().replace(/[-:]/g, '').split('.')[0] + 'Z';\nconst icsText = 'BEGIN:VCALENDAR\\r\\nVERSION:2.0\\r\\nPRODID:-//Clinica Local//NONSGML Citas//ES\\r\\nCALSCALE:GREGORIAN\\r\\nMETHOD:PUBLISH\\r\\nBEGIN:VEVENT\\r\\nUID:' + patientData.numero_cita + '@clinica.local\\r\\nDTSTAMP:' + dtstamp + '\\r\\nDTSTART;TZID=America/Guatemala:' + dtstart + '\\r\\nDTEND;TZID=America/Guatemala:' + dtend + '\\r\\nSUMMARY:Cita Medica - ' + patientData.paciente_nombre + '\\r\\nDESCRIPTION:Cita de ' + patientData.especialidad + ' con ' + (patientData.doctor || 'Sin preferencia') + '. Motivo: ' + (patientData.motivo || 'No especificado') + '\\r\\nLOCATION:Clinica Local\\r\\nEND:VEVENT\\r\\nEND:VCALENDAR';\nreturn {\n  json: patientData,\n  binary: {\n    attachment: {\n      data: Buffer.from(icsText).toString('base64'),\n      mimeType: 'text/calendar',\n      fileName: 'cita.ics'\n    }\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1600,
        -400
      ],
