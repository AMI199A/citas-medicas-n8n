    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const item = $input.item.json;\nconst fecha = item.fecha_cita.replace(/-/g, '');\nconst rand = Math.floor(Math.random() * 9000) + 1000;\nconst esp = item.especialidad.substring(0, 3).toUpperCase();\nconst numeroCita = `CIT-${esp}-${fecha}-${rand}`;\n\nreturn {\n  json: {\n    ...item,\n    numero_cita: numeroCita\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
